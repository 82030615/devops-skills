{
  "skill_name": "java-deep-analysis",
  "evals": [
    {
      "id": 1,
      "name": "订单状态机分析",
      "prompt": "请分析订单模块的状态机功能，入口是 OrderService 的 processOrder 方法。需要输出类图、状态机图、时序图和控制流程图。",
      "expected_output": "包含Mermaid类图、状态图、时序图、流程图的Markdown分析报告，包含分析置信度表格",
      "expectations": [
        {"type": "contains", "value": "## 分析置信度"},
        {"type": "regex", "pattern": "```mermaid\\s*\\nclassDiagram", "description": "包含类图"},
        {"type": "regex", "pattern": "```mermaid\\s*\\nstateDiagram-v2", "description": "包含状态图"},
        {"type": "regex", "pattern": "```mermaid\\s*\\nsequenceDiagram", "description": "包含时序图"},
        {"type": "regex", "pattern": "```mermaid\\s*\\nflowchart", "description": "包含流程图"},
        {"type": "regex", "pattern": "`[a-z][\\w.]*\\.[A-Z]\\w+`", "min_count": 3, "description": "至少3个FQCN标注"},
        {"type": "regex", "pattern": "(未捕获异常|并发安全|边界参数)", "description": "包含异常或边界分析"}
      ]
    },
    {
      "id": 2,
      "name": "支付流程分析",
      "prompt": "对 PaymentService 进行深度分析，重点关注支付状态流转、异常处理路径和事务边界。",
      "expected_output": "支付模块的完整分析报告，包含状态转换和异常路径，包含置信度评分",
      "expectations": [
        {"type": "contains", "value": "## 分析置信度"},
        {"type": "regex", "pattern": "stateDiagram-v2", "description": "包含状态机图"},
        {"type": "regex", "pattern": "@Transactional", "description": "标注事务边界"},
        {"type": "regex", "pattern": "(throws|Exception|Error)", "description": "分析异常路径"},
        {"type": "regex", "pattern": "sequenceDiagram", "description": "生成时序图展示调用链"}
      ]
    },
    {
      "id": 3,
      "name": "工作流引擎分析",
      "prompt": "分析 WorkflowEngine 的核心逻辑，包括任务调度、状态管理和扩展点设计模式。",
      "expected_output": "工作流引擎的架构分析报告，包含设计模式识别",
      "expectations": [
        {"type": "regex", "pattern": "(设计模式|观察者|责任链|策略模式|工厂模式)", "description": "识别设计模式"},
        {"type": "regex", "pattern": "(扩展点|插件|Extension|Plugin)", "description": "分析扩展点"},
        {"type": "regex", "pattern": "classDiagram", "description": "生成类图"},
        {"type": "regex", "pattern": "(synchronized|volatile|并发|线程)", "description": "标注并发控制"}
      ]
    },
    {
      "id": 4,
      "name": "权限验证模块分析",
      "prompt": "深度分析 AuthService 的权限验证逻辑，包括认证流程、权限校验链和缓存机制。",
      "expected_output": "权限模块的完整调用链和状态分析",
      "expectations": [
        {"type": "regex", "pattern": "(责任链|拦截器|Filter|Interceptor|Chain)", "description": "识别责任链或拦截器模式"},
        {"type": "regex", "pattern": "(Cache|缓存|Redis|Cacheable)", "description": "分析缓存策略"},
        {"type": "regex", "pattern": "sequenceDiagram", "description": "生成时序图"},
        {"type": "regex", "pattern": "(Security|安全|权限|认证)", "description": "标注安全配置"}
      ]
    },
    {
      "id": 5,
      "name": "负面测试-简单查询",
      "prompt": "帮我找一下 UserService 的 getUserById 方法在哪里",
      "expected_output": "技能不应触发深度分析，或仅提供简单定位信息",
      "expectations": [
        {"type": "not_contains", "value": "```mermaid", "description": "不提供Mermaid图表"},
        {"type": "not_contains", "value": "classDiagram", "description": "不生成类图"},
        {"type": "not_contains", "value": "分析置信度", "description": "不提供深度分析结构"},
        {"type": "regex", "pattern": "(位于|在|行号|line)", "description": "提供简单位置信息"}
      ]
    },
    {
      "id": 6,
      "name": "负面测试-非Java代码分析",
      "prompt": "请分析这个Python项目的main.py文件的结构",
      "expected_output": "礼貌拒绝，说明技能仅支持Java代码分析",
      "expectations": [
        {"type": "regex", "pattern": "(不支持|仅支持|抱歉|Sorry)", "description": "礼貌拒绝"},
        {"type": "regex", "pattern": "Java", "description": "说明仅支持Java"},
        {"type": "not_contains", "value": "classDiagram", "description": "不生成类图"},
        {"type": "not_contains", "value": "stateDiagram", "description": "不生成状态图"}
      ]
    },
    {
      "id": 7,
      "name": "负面测试-入口类不存在",
      "prompt": "分析 NonExistentService 的业务逻辑",
      "expected_output": "提示未找到类，提供相似类名推荐或询问用户",
      "expectations": [
        {"type": "regex", "pattern": "(未找到|不存在|not found|不存在)", "description": "告知未找到"},
        {"type": "regex", "pattern": "(是否指|推荐|similar|similar)", "description": "提供推荐或询问"},
        {"type": "not_contains", "value": "## 分析置信度", "description": "不输出虚假分析报告"}
      ]
    },
    {
      "id": 8,
      "name": "边界测试-超大规模分析",
      "prompt": "分析整个Spring框架的Bean生命周期管理模块",
      "expected_output": "识别类数量过多，提示范围控制策略，仅分析核心路径",
      "expectations": [
        {"type": "regex", "pattern": "(类过多|范围|核心路径|范围控制)", "description": "识别范围控制需求"},
        {"type": "regex", "pattern": "P[0-2].*优先", "description": "按优先级排序"},
        {"type": "contains", "value": "## 分析置信度", "description": "仍提供置信度"}
      ]
    },
    {
      "id": 9,
      "name": "质量测试-图表规范检查",
      "prompt": "分析 OrderService 的订单创建流程，确保Mermaid图表符合规范",
      "expected_output": "所有Mermaid图表符合语法规范，包含FQCN标注",
      "expectations": [
        {"type": "regex", "pattern": "--\\|>", "description": "继承关系使用--|>"},
        {"type": "regex", "pattern": "->>", "description": "时序图使用->>表示同步调用"},
        {"type": "regex", "pattern": "`[a-z][\\w.]*\\.[A-Z]\\w+`", "min_count": 5, "description": "至少5个FQCN标注"}
      ]
    },
    {
      "id": 10,
      "name": "质量测试-错误处理验证",
      "prompt": "分析一个使用了反射和动态代理的服务类",
      "expected_output": "正确识别反射和代理导致的不确定调用，降低相关维度置信度",
      "expectations": [
        {"type": "regex", "pattern": "(反射|动态代理|Proxy|invoke)", "description": "识别反射/代理"},
        {"type": "regex", "pattern": "置信度.*[0-9]+%", "description": "提供置信度百分比"},
        {"type": "regex", "pattern": "(无法分析|无法静态分析|建议运行时)", "description": "说明局限性"}
      ]
    }
  ]
}
